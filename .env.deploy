# --- Critical Security ---
BETTER_AUTH_SECRET==

# --- Networking ---
PAPERCLIP_PUBLIC_URL=https://example.com
PAPERCLIP_DEPLOYMENT_MODE=authenticated
PAPERCLIP_DEPLOYMENT_EXPOSURE=public

# --- Database ---
# Internal Docker network link to the 'db' service
# !! IMPORTANT: Change 'password' below to a strong random string !!
DATABASE_URL=postgres://paperclip:password@db:5432/paperclip
POSTGRES_PASSWORD=password

# --- AI Providers (Ollama / OpenCode) ---
# Use host.docker.internal to talk to Ollama running on your VM host
OLLAMA_BASE_URL=http://host.docker.internal:11434

# --- Access Control ---
# Set to 'false' for your first login, then change to 'true' to lock the site.
PAPERCLIP_AUTH_DISABLE_SIGN_UP=false
